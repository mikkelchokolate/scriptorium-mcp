{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scriptorium Ontology Plugin Schema",
  "description": "Schema for custom ontology plugins in Scriptorium MCP",
  "type": "object",
  "required": ["name", "version", "entityTypes", "relationTypes"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "description": "Human-readable ontology name" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "entityTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9]+$" },
          "description": { "type": "string" },
          "properties": { "type": "array", "items": { "type": "string" } },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    },
    "relationTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "from", "to"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z_]+$" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "consistencyRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "severity"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "query": { "type": "string", "description": "Cypher query to detect violations" },
          "severity": { "type": "string", "enum": ["info", "warning", "error"] }
        }
      }
    }
  }
}
