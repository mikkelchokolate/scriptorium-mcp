{
  "name": "scriptorium-mcp",
  "version": "1.2.0",
  "description": "Scriptorium MCP - file-first writing workspace with optional graph and ontology extensions",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:web": "npm --prefix web run build",
    "build:all": "npm run build && npm run build:web",
    "start": "node --env-file-if-exists=.env.local dist/index.js",
    "dev": "node --env-file-if-exists=.env.local --import tsx src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "neo4j:up": "node scripts/neo4j-compose.mjs up",
    "neo4j:down": "node scripts/neo4j-compose.mjs down",
    "neo4j:logs": "node scripts/neo4j-compose.mjs logs",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "eventemitter3": "^5.0.4",
    "fs-extra": "^11.2.0",
    "neo4j-driver": "^5.28.3",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
